{
  "name": "@tetris/engine",
  "version": "0.1.0",
  "description": "Headless, deterministic, Guideline-compliant Tetris game engine with replay, events, and serialization. Pure TypeScript with zero framework dependencies.",
  "keywords": [
    "canvas",
    "deterministic",
    "engine",
    "game",
    "guideline",
    "replay",
    "srs",
    "tetris",
    "tetromino"
  ],
  "homepage": "https://github.com/chicong065/tetris-toolkit#readme",
  "bugs": {
    "url": "https://github.com/chicong065/tetris-toolkit/issues"
  },
  "license": "MIT",
  "author": "Cong Nguyen",
  "repository": {
    "type": "git",
    "url": "https://github.com/chicong065/tetris-toolkit"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "tsup": "^8.5.1",
    "typescript": "~5.9.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18"
  }
}
